# Demo configuration — copy this file to `.env` and fill in.
# `demos/.env` is gitignored; this template is committed.
# Loaded automatically by the demo (see demos/_env.py). Shell exports override it.

# ── Licensed GMS backend ──────────────────────────────────────────────
# Needed for the GMS sections. Leave blank to run the open baseline only.
KNOWLYTIX_LICENSE_KEY=
# KNOWLYTIX_INDEX_URL=                  # private package index, for `pip install knowlytix`
# GMS_BANKING_STORE=                    # default: demos/data/gms_banking_store

# ── Judge LLM (Capability 2) ──────────────────────────────────────────
# Pick ONE provider. Default (unset) auto-detects from available keys.
LLM_PROVIDER=anthropic                  # anthropic | openai | qwen | mock
# LLM_MODEL=                            # blank = provider default (claude-sonnet-4-6 / gpt-4o-mini)
ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
